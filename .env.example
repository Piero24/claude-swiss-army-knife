# ============================================================
# .env — Central configuration for the entire MCP stack
# Copy this file to .env and fill in your values
# ============================================================

# ---- Server Connectivity ----
UBUNTU_SERVER_HOST=your-server.example.com
UBUNTU_SERVER_SSH_PORT=22
UBUNTU_SERVER_USER=apietrobon

# ---- Container Names ----
UBUNTU_MCP_CONTAINER=ubuntu-mcp
OBSIDIAN_MCP_CONTAINER=obsidian-mcp
SYNOLOGY_MCP_CONTAINER=synology-mcp

# ---- Synology NAS (DSM 7.x, same LAN as Ubuntu server) ----
SYNOLOGY_NAS_HOST=192.168.1.100
SYNOLOGY_NAS_PORT=5001
SYNOLOGY_NAS_USER=your-nas-username
SYNOLOGY_NAS_PASSWORD=your-nas-password
# Base32 TOTP secret — only needed if 2FA is enabled on the NAS account
# Copy only the "secret=" value from your otpauth:// URL
SYNOLOGY_NAS_OTP_SECRET=

# ---- Obsidian ----
# Path to Obsidian Live Sync CouchDB data (already exists)
OBSIDIAN_LIVESYNC_DATA=/DATA/AppData/big-bear-obsidian-livesync/data
# Path to the Obsidian vault on the server (plain .md files synced via Live Sync)
OBSIDIAN_VAULT_PATH=/DATA/obsidian-vaults/personal

# ---- Web UI ----
WEBUI_IMAGE_TAG=latest
# Generate with: bash scripts/generate-api-key.sh
WEBUI_API_KEY=change-me-to-a-strong-random-64-char-key
# Generate with: openssl rand -hex 32
WEBUI_AUTH_SECRET=change-me-to-a-random-hex-string
WEBUI_PORT=8280

# ---- Documentation Site ----
DOCS_IMAGE_TAG=latest
DOCS_PORT=3000

# ---- Docker Image Tags ----
UBUNTU_MCP_IMAGE_TAG=latest
OBSIDIAN_MCP_IMAGE_TAG=latest
SYNOLOGY_MCP_IMAGE_TAG=latest

# ---- Logging ----
MCP_LOG_DIR=/var/log/mcp
MCP_LOG_LEVEL=INFO
